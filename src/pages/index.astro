---
// CashFlowfy Landing Page
// BPO Financeiro Inteligente — SaaS + BPO Humano + IA
const WHATSAPP_URL = "https://wa.me/5511999999999?text=Olá!%20Quero%20saber%20mais%20sobre%20o%20CashFlowfy";
const SITE_URL = "https://cashflowfy.com.br";
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <!-- =============================================
         SEO: Meta tags otimizadas para Google e Ads
         ============================================= -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Title otimizado para SEO — BPO Financeiro | Gestão Financeira -->
    <title>CashFlowfy | BPO Financeiro Inteligente para Empresas — SaaS + IA + Execução Real</title>

    <!-- Meta description com palavras-chave prioritárias -->
    <meta
      name="description"
      content="CashFlowfy é o BPO financeiro inteligente para empresas. Terceirize sua gestão financeira com tecnologia, automação com IA e execução real. Contas a pagar e receber, fluxo de caixa e cobranças — tudo automatizado."
    />

    <!-- Keywords -->
    <meta
      name="keywords"
      content="BPO financeiro, terceirização financeira, gestão financeira empresas, contas a pagar e receber, automação financeira, fluxo de caixa, BPO as a service, financeiro empresarial, controle financeiro"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:title" content="CashFlowfy | BPO Financeiro Inteligente — Seu financeiro no piloto automático" />
    <meta property="og:description" content="SaaS + BPO humano + automação com IA. Nós organizamos, executamos e automatizamos seu financeiro — você só aprova." />
    <meta property="og:image" content={`${SITE_URL}/og-image.png`} />
    <meta property="og:locale" content="pt_BR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="CashFlowfy | BPO Financeiro Inteligente" />
    <meta name="twitter:description" content="Terceirize seu financeiro com tecnologia, BPO humano e automação com IA." />

    <!-- Canonical -->
    <link rel="canonical" href={SITE_URL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Space Grotesk + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Google Tag Manager (placeholder) -->
    <!-- <script>(function(w,d,s,l,i){...})(window,document,'script','dataLayer','GTM-XXXXXX');</script> -->

    <!-- Schema.org structured data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "CashFlowfy",
        "description": "BPO Financeiro Inteligente — SaaS + BPO Humano + Automação com IA",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web",
        "offers": {
          "@type": "Offer",
          "price": "497",
          "priceCurrency": "BRL"
        },
        "provider": {
          "@type": "Organization",
          "name": "The Retech",
          "url": "https://theretech.com.br"
        }
      }
    </script>

    <style>
      /* ============================================
         Global styles
         ============================================ */
      * {
        scroll-behavior: smooth;
      }

      body {
        background-color: #0a0a0a;
        color: #ffffff;
        font-family: 'Inter', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      /* Neon text effect */
      .neon-text {
        color: #00FF88;
        text-shadow: 0 0 12px rgba(0, 255, 136, 0.5);
      }

      /* Gradient neon line */
      .neon-line {
        height: 1px;
        background: linear-gradient(90deg, transparent, #00FF88, transparent);
      }

      /* Neon line automática no topo de cada seção */
      section {
        position: relative;
      }

      section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, #00FF88, transparent);
      }

      /* Grid pattern background */
      .grid-bg {
        background-image:
          linear-gradient(rgba(0, 255, 136, 0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0, 255, 136, 0.03) 1px, transparent 1px);
        background-size: 40px 40px;
      }

      /* Radial glow */
      .hero-glow {
        background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(0, 255, 136, 0.12), transparent);
      }

      /* Card hover */
      .card-hover {
        transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
      }
      .card-hover:hover {
        border-color: rgba(0, 255, 136, 0.4);
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(0, 255, 136, 0.08);
      }

      /* Pill badge */
      .badge-neon {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 9999px;
        border: 1px solid rgba(0, 255, 136, 0.3);
        background: rgba(0, 255, 136, 0.05);
        color: #00FF88;
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      /* Scroll fade-in animation */
      .fade-in {
        opacity: 0;
        transform: translateY(24px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }
      .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* WhatsApp message bubble */
      .bubble {
        background: #1e1e1e;
        border: 1px solid #2a2a2a;
        border-radius: 0 12px 12px 12px;
      }
      .bubble-out {
        background: rgba(0, 255, 136, 0.08);
        border: 1px solid rgba(0, 255, 136, 0.2);
        border-radius: 12px 0 12px 12px;
        margin-left: auto;
      }

      @media (prefers-reduced-motion: reduce) {
        .fade-in {
          opacity: 1;
          transform: none;
          transition: none;
        }
        * {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </head>

  <body class="bg-[#0a0a0a] text-white overflow-x-hidden">

    <!-- =============================================
         NAVBAR — Sticky, translucent
         ============================================= -->
    <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-[#0a0a0a]/80">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" aria-label="CashFlowfy - Início" class="flex items-center gap-2 cursor-pointer">
          <div class="w-8 h-8 rounded-lg bg-[#00FF88] flex items-center justify-center">
            <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" aria-hidden="true">
              <!-- Sparkline ascendente: representa fluxo e ganho financeiro -->
              <polyline points="2,17 7,11 12,13.5 16.5,7" stroke="black" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              <!-- Seta no topo direito indicando crescimento -->
              <path d="M13.5 4.5H21V12" stroke="black" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              <line x1="16.5" y1="7" x2="21" y2="4.5" stroke="black" stroke-width="2.2" stroke-linecap="round"/>
            </svg>
          </div>
          <span class="font-display font-700 text-lg tracking-tight text-white">Cash<span class="neon-text">Flowfy</span></span>
        </a>

        <!-- Nav Links — Desktop -->
        <nav class="hidden md:flex items-center gap-8 text-sm text-gray-400" aria-label="Navegação principal">
          <a href="#como-funciona" class="hover:text-white transition-colors duration-200 cursor-pointer">Como funciona</a>
          <a href="#diferenciais" class="hover:text-white transition-colors duration-200 cursor-pointer">Diferenciais</a>
          <a href="#planos" class="hover:text-white transition-colors duration-200 cursor-pointer">Planos</a>
        </nav>

        <!-- CTA Nav -->
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[#00FF88] text-black font-semibold text-sm hover:bg-[#00cc6a] transition-colors duration-200 cursor-pointer"
          aria-label="Falar no WhatsApp"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.137.558 4.14 1.535 5.875L.057 23.5l5.797-1.522A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.9 0-3.676-.497-5.21-1.367l-.373-.222-3.44.904.919-3.354-.241-.387A9.96 9.96 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
          Falar no WhatsApp
        </a>
      </div>
      <!-- Neon divider na base do header — separa header do hero -->
      <div class="neon-line" aria-hidden="true"></div>
    </header>

    <!-- =============================================
         SEÇÃO 1: HERO — Extremamente forte
         H1 otimizado para SEO
         ============================================= -->
    <section class="relative min-h-screen flex items-center pt-16 hero-glow grid-bg overflow-hidden" aria-labelledby="hero-heading">
      <!-- Decorative blobs -->
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-[#00FF88]/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 text-center">
        <!-- Badge -->
        <div class="flex justify-center mb-6 fade-in">
          <span class="badge-neon">
            <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" aria-hidden="true">
              <circle cx="12" cy="12" r="3" fill="#00FF88"/>
              <circle cx="12" cy="12" r="7" stroke="#00FF88" stroke-width="1.5" fill="none"/>
            </svg>
            BPO Financeiro Inteligente
          </span>
        </div>

        <!-- H1 — SEO prioritário -->
        <h1
          id="hero-heading"
          class="font-display font-extrabold text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-tight tracking-tight mb-6 fade-in"
          style="animation-delay: 0.1s"
        >
          Seu financeiro no<br />
          <span class="neon-text">piloto automático.</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-gray-400 text-lg sm:text-xl md:text-2xl max-w-3xl mx-auto leading-relaxed mb-8 fade-in" style="animation-delay: 0.2s">
          SaaS + BPO humano + automação com IA.<br class="hidden sm:block" />
          Nós organizamos, executamos e automatizamos seu financeiro —<br class="hidden md:block" />
          <strong class="text-white">você só aprova.</strong>
        </p>

        <!-- Bullets rápidos -->
        <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2 mb-10 text-sm text-gray-400 fade-in" style="animation-delay: 0.3s" aria-label="Principais benefícios">
          {[
            'Pagamentos organizados e executados',
            'Aprovação via WhatsApp',
            'Automação com IA',
            'Controle total sem esforço',
          ].map((item) => (
            <li class="flex items-center gap-2">
              <svg viewBox="0 0 20 20" fill="none" class="w-4 h-4 shrink-0" aria-hidden="true">
                <path d="M7 10l2.5 2.5L14 7" stroke="#00FF88" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="10" cy="10" r="8.5" stroke="#00FF88" stroke-width="1"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 fade-in" style="animation-delay: 0.4s">
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-[#00FF88] text-black font-bold text-base hover:bg-[#00cc6a] transition-all duration-200 shadow-[0_0_20px_rgba(0,255,136,0.4)] hover:shadow-[0_0_30px_rgba(0,255,136,0.6)] cursor-pointer"
            aria-label="Quero organizar meu financeiro — falar no WhatsApp"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.137.558 4.14 1.535 5.875L.057 23.5l5.797-1.522A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.9 0-3.676-.497-5.21-1.367l-.373-.222-3.44.904.919-3.354-.241-.387A9.96 9.96 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
            Quero organizar meu financeiro
          </a>
          <a
            href="#como-funciona"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl border border-[#2a2a2a] text-gray-300 font-medium text-base hover:border-[#00FF88]/40 hover:text-white transition-all duration-200 cursor-pointer"
            aria-label="Entender como funciona"
          >
            Como funciona
            <svg viewBox="0 0 20 20" fill="none" class="w-4 h-4" aria-hidden="true">
              <path d="M10 4v12M4 10l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <!-- Social proof stats -->
        <div class="mt-16 grid grid-cols-3 gap-4 max-w-md mx-auto border border-[#1e1e1e] rounded-2xl p-4 bg-[#111111]/50 fade-in" style="animation-delay: 0.5s" aria-label="Estatísticas">
          {[
            { value: '100%', label: 'Digital' },
            { value: '24h', label: 'Ativação' },
            { value: '0', label: 'Stress' },
          ].map((stat) => (
            <div class="text-center">
              <div class="font-display font-bold text-2xl neon-text">{stat.value}</div>
              <div class="text-gray-500 text-xs mt-0.5">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- =============================================
         SEÇÃO 2: PROBLEMA — Dores reais do cliente
         H2 para SEO
         ============================================= -->
    <section class="pt-16 pb-24" aria-labelledby="problema-heading">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <!-- Header -->
        <div class="text-center mb-16 fade-in">
          <span class="badge-neon mb-4 inline-flex">O problema</span>
          <h2 id="problema-heading" class="font-display font-bold text-3xl sm:text-4xl md:text-5xl leading-tight mb-4">
            Seu financeiro está<br />
            <span class="text-red-400">te sabotando</span>
          </h2>
          <p class="text-gray-400 text-lg max-w-2xl mx-auto">
            A maioria das empresas perde dinheiro e oportunidades por não ter o financeiro organizado. Reconhece algum desses cenários?
          </p>
        </div>

        <!-- Pain cards grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4" role="list" aria-label="Principais dores financeiras">
          {[
            {
              icon: `<path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
              title: 'Contas perdidas',
              desc: 'Boletos vencendo sem aviso, multas por esquecimento e cheque especial no fim do mês.',
            },
            {
              icon: `<path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
              title: 'Falta de tempo',
              desc: 'Você passa horas em planilhas quando deveria estar focado em crescer seu negócio.',
            },
            {
              icon: `<path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
              title: 'Zero visibilidade',
              desc: 'Sem saber o saldo real do caixa, você toma decisões no escuro e corre riscos desnecessários.',
            },
            {
              icon: `<path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>`,
              title: 'Inadimplência escondida',
              desc: 'Clientes em atraso que você não cobra por falta de processo. Dinheiro parado que deveria estar no seu caixa.',
            },
          ].map((pain) => (
            <div class="bg-[#111111] border border-[#1e1e1e] rounded-2xl p-6 card-hover" role="listitem">
              <div class="w-10 h-10 rounded-lg bg-red-500/10 border border-red-500/20 flex items-center justify-center mb-4">
                <svg viewBox="0 0 24 24" class="w-5 h-5 text-red-400" aria-hidden="true">
                  <Fragment set:html={pain.icon} />
                </svg>
              </div>
              <h3 class="font-display font-semibold text-white mb-2">{pain.title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{pain.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- =============================================
         SEÇÃO 3: SOLUÇÃO — O que é o CashFlowfy
         ============================================= -->
    <section class="pt-16 pb-24 bg-[#0d0d0d]" aria-labelledby="solucao-heading">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <!-- Left: text -->
          <div class="fade-in">
            <span class="badge-neon mb-6 inline-flex">A solução</span>
            <h2 id="solucao-heading" class="font-display font-bold text-3xl sm:text-4xl md:text-5xl leading-tight mb-6">
              Não é só sistema.<br />
              Não é só consultoria.<br />
              <span class="neon-text">É execução real.</span>
            </h2>
            <p class="text-gray-400 text-lg leading-relaxed mb-8">
              O CashFlowfy é um <strong class="text-white">BPO Financeiro as a Service</strong> que combina plataforma inteligente, time especializado e automação com IA para cuidar do financeiro da sua empresa de ponta a ponta.
            </p>
            <ul class="space-y-4" aria-label="O que o CashFlowfy faz">
              {[
                'Organizamos e executamos todos os seus pagamentos',
                'Realizamos cobranças e conciliações bancárias',
                'Automatizamos alertas e aprovações via WhatsApp',
                'Entregamos relatórios e visibilidade do fluxo de caixa',
              ].map((item) => (
                <li class="flex items-start gap-3 text-gray-300">
                  <svg viewBox="0 0 20 20" fill="none" class="w-5 h-5 shrink-0 mt-0.5" aria-hidden="true">
                    <path d="M7 10l2.5 2.5L14 7" stroke="#00FF88" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="10" cy="10" r="8.5" stroke="#00FF88" stroke-width="1"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <!-- Right: visual comparison card -->
          <div class="fade-in">
            <div class="bg-[#111111] border border-[#1e1e1e] rounded-2xl p-6 space-y-4">
              <p class="text-gray-500 text-xs uppercase tracking-widest mb-4">CashFlowfy vs outros</p>
              <div class="space-y-3">
                {[
                  { label: 'Só sistema (ERP)', checks: [true, false, false] },
                  { label: 'Só consultoria', checks: [false, true, false] },
                  { label: 'CashFlowfy BPO', checks: [true, true, true], highlight: true },
                ].map((row) => (
                  <div class={`flex items-center gap-3 p-3 rounded-xl ${row.highlight ? 'bg-[#00FF88]/5 border border-[#00FF88]/20' : 'bg-[#161616]'}`}>
                    <span class={`text-sm font-medium flex-1 ${row.highlight ? 'text-white font-semibold' : 'text-gray-400'}`}>{row.label}</span>
                    {['Plataforma', 'Execução', 'Automação IA'].map((col, i) => (
                      <div class="flex flex-col items-center gap-1 min-w-[60px]">
                        <span class="text-[10px] text-gray-600 hidden sm:block">{col}</span>
